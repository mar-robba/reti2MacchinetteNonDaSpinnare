@page
@model SmartFeederWebApp.Pages.Distributori.IndexModel
@{
    ViewData["Title"] = "Distributori";
}

<h2>Distributori @(Model.NomeParco != null ? $"- {Model.NomeParco}" : "")</h2>

@if (User.Identity?.IsAuthenticated == true && User.IsInRole("admin"))
{
    <form method="post" asp-page-handler="Create" class="mb-3">
        <input type="hidden" name="idParco" value="@Model.IdParco" />
        <button type="submit" class="btn btn-primary">+ Nuovo Distributore</button>
    </form>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Parco</th>
            <th>Stato</th>
            <th>Online</th>
            <th>Ultimo Contatto</th>
            <th>Azioni</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Distributori != null)
        {
            @foreach (var d in Model.Distributori)
            {
                <tr class="@(d.Guasta ? "table-danger" : "")">
                    <td>@d.Id</td>
                    <td>@d.NomeParco</td>
                    <td>
                        @if (d.Guasta)
                        {
                            <span class="badge bg-danger">Guasto</span>
                        }
                        else
                        {
                            <span class="badge bg-success">OK</span>
                        }
                    </td>
                    <td>
                        @if (d.Online)
                        {
                            <span class="badge bg-success">Online</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Offline</span>
                        }
                    </td>
                    <td>@d.UltimoContatto</td>
                    <td>
                        @if (User.IsInRole("admin"))
                        {
                            <form method="post" asp-page-handler="Delete" style="display:inline;">
                                <input type="hidden" name="id" value="@d.Id" />
                                <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Eliminare questo distributore?')">Elimina</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<a href="/Parchi" class="btn btn-secondary">← Torna ai Parchi</a>
