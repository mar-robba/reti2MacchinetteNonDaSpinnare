@page
@model SmartFeederWebApp.Pages.Interventi.IndexModel
@{
    ViewData["Title"] = "Dashboard Manutenzione";
}

<h2>Ticket di Manutenzione</h2>

<div class="mb-3">
    <a href="/Interventi?stato=" class="btn btn-outline-secondary @(Model.FiltroStato == null ? "active" : "")">Tutti</a>
    <a href="/Interventi?stato=aperta" class="btn btn-outline-danger @(Model.FiltroStato == "aperta" ? "active" : "")">Aperti</a>
    <a href="/Interventi?stato=in_corso" class="btn btn-outline-warning @(Model.FiltroStato == "in_corso" ? "active" : "")">In Corso</a>
    <a href="/Interventi?stato=risolta" class="btn btn-outline-success @(Model.FiltroStato == "risolta" ? "active" : "")">Risolti</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tipo Guasto</th>
            <th>Distributore</th>
            <th>Parco</th>
            <th>Data</th>
            <th>Stato</th>
            <th>Azioni</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Ticket != null)
        {
            @foreach (var t in Model.Ticket)
            {
                <tr class="@(t.Stato == "aperta" ? "table-danger" : t.Stato == "in_corso" ? "table-warning" : "table-success")">
                    <td>@t.Id</td>
                    <td>@t.TipoGuasto</td>
                    <td>Distributore #@t.IdDistributore</td>
                    <td>@t.NomeParco</td>
                    <td>@t.TimestampRichiesta</td>
                    <td>
                        @if (t.Stato == "aperta")
                        {
                            <span class="badge bg-danger">Aperta</span>
                        }
                        else if (t.Stato == "in_corso")
                        {
                            <span class="badge bg-warning text-dark">In Corso</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Risolta</span>
                        }
                    </td>
                    <td>
                        @if (t.Stato != "risolta")
                        {
                            <form method="post" asp-page-handler="Risolvi" style="display:inline;">
                                <input type="hidden" name="ticketId" value="@t.Id" />
                                <button type="submit" class="btn btn-sm btn-success">
                                    ✅ Risolto in loco
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
