@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">🐦 Smart Feeder</h1>
    <p class="lead">Sistema di gestione distributori automatici di mangime per animali</p>
    <hr />
</div>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">🏞️ Parchi</h5>
                <p class="card-text">Visualizza e gestisci i parchi dove sono installati i distributori.</p>
                <a href="/Parchi" class="btn btn-primary">Vai ai Parchi</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">📦 Distributori</h5>
                <p class="card-text">Controlla lo stato dei distributori e le spie di guasto.</p>
                <a href="/Distributori" class="btn btn-primary">Vai ai Distributori</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">🔧 Interventi</h5>
                <p class="card-text">Dashboard manutenzione: ticket aperti e gestione interventi.</p>
                <a href="/Interventi" class="btn btn-primary">Vai agli Interventi</a>
            </div>
        </div>
    </div>
</div>
