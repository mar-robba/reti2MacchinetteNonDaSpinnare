@page
@model PissirWebApp.Pages.AggiungiMacchinettaModel
@{
    ViewData["Title"] = "Aggiungi Macchinetta";
}

<div class="card">
    <h2>☕ Aggiungi Macchinetta</h2>

    @if (!string.IsNullOrEmpty(Model.Messaggio))
    {
        <div class="alert alert-success">@Model.Messaggio</div>
    }
    @if (!string.IsNullOrEmpty(Model.Errore))
    {
        <div class="alert alert-error">@Model.Errore</div>
    }

    <form method="post">
        <div class="form-group">
            <label for="idScuola">Scuola *</label>
            <select id="idScuola" name="IdScuola" required>
                <option value="">-- Seleziona una scuola --</option>
                @if (Model.Scuole != null)
                {
                    foreach (var scuola in Model.Scuole)
                    {
                        <option value="@scuola.Id">@scuola.Nome</option>
                    }
                }
            </select>
        </div>
        <div class="form-group">
            <label for="nome">Nome Macchinetta *</label>
            <input type="text" id="nome" name="Nome" required value="@Model.Nome" />
        </div>
        <button type="submit" class="btn btn-primary">Aggiungi Macchinetta</button>
        <a href="/AggiungiScuola" class="btn btn-warning" style="margin-left: 10px;">Crea Nuova Scuola</a>
        <a href="/MenuAmministratore" class="btn btn-danger" style="margin-left: 10px;">Annulla</a>
    </form>
</div>
