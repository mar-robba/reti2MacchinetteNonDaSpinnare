{
  "realm": "smartfeeder",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "admin", "description": "Amministratore - gestione parchi e distributori" },
      { "name": "employee", "description": "Impiegato - visualizzazione parchi e distributori" },
      { "name": "technician", "description": "Tecnico - gestione ticket manutenzione" }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@smartfeeder.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "realmRoles": ["admin", "employee"]
    },
    {
      "username": "impiegato",
      "enabled": true,
      "email": "impiegato@smartfeeder.local",
      "firstName": "Marco",
      "lastName": "Impiegato",
      "credentials": [
        { "type": "password", "value": "impiegato", "temporary": false }
      ],
      "realmRoles": ["employee"]
    },
    {
      "username": "tecnico",
      "enabled": true,
      "email": "tecnico@smartfeeder.local",
      "firstName": "Luca",
      "lastName": "Tecnico",
      "credentials": [
        { "type": "password", "value": "tecnico", "temporary": false }
      ],
      "realmRoles": ["technician"]
    }
  ],
  "clients": [
    {
      "clientId": "server-rest-client",
      "enabled": true,
      "publicClient": false,
      "secret": "server-rest-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:8081/*"],
      "webOrigins": ["http://localhost:8081"],
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "webapp-client",
      "enabled": true,
      "publicClient": false,
      "secret": "webapp-secret",
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:5000/*", "https://localhost:5001/*"],
      "webOrigins": ["http://localhost:5000", "https://localhost:5001"],
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    }
  ],
  "clientScopes": [
    {
      "name": "openid",
      "protocol": "openid-connect"
    },
    {
      "name": "profile",
      "protocol": "openid-connect"
    },
    {
      "name": "email",
      "protocol": "openid-connect"
    },
    {
      "name": "roles",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ]
}
